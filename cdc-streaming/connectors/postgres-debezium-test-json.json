{
  "name": "postgres-cdc-test-json",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",
    
    "database.hostname": "car_entities_postgres_large",
    "database.port": "5432",
    "database.user": "postgres",
    "database.password": "password",
    "database.dbname": "car_entities",
    "database.server.name": "postgres-cdc",
    
    "topic.prefix": "cdc-raw",
    "table.include.list": "public.car_entities,public.loan_entities",
    
    "plugin.name": "pgoutput",
    "slot.name": "cdc_test_slot",
    "publication.name": "cdc_test_publication",
    "publication.autocreate.mode": "filtered",
    
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    
    "producer.bootstrap.servers": "pkc-oxqxx9.us-east-1.aws.confluent.cloud:9092",
    "producer.security.protocol": "SASL_SSL",
    "producer.sasl.mechanism": "PLAIN",
    "producer.sasl.jaas.config": "org.apache.kafka.common.security.plain.PlainLoginModule required username=\"A57DHIMR3NLB6PGI\" password=\"cfltawpq47RbFYepsUN3x0whOK4tgfMbGweGAp1eNdULMf/W2RMwiLJFVPyoTxkg\";",
    
    "snapshot.mode": "never",
    "tombstones.on.delete": "true",
    "include.schema.changes": "false",
    
    "transforms": "unwrap,route",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "false",
    "transforms.unwrap.add.fields": "op,table,ts_ms",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "cdc-raw.public.(.*)",
    "transforms.route.replacement": "raw-business-events",
    
    "errors.tolerance": "all",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true"
  }
}

